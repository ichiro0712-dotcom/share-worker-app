NEXT_PUBLIC_FEATURE_HIBARAI=false

# GMO Aozora Net Bank API
GMO_AOZORA_MODE=dummy
GMO_AOZORA_BASE_URL=https://stg-api.gmo-aozora.com
GMO_AOZORA_CLIENT_ID=
GMO_AOZORA_CLIENT_SECRET=
GMO_AOZORA_WEBHOOK_SECRET=
GMO_AOZORA_ACCOUNT_TYPE=corporate
GMO_AOZORA_REDIRECT_URI=http://localhost:3000/api/gmo/oauth/callback
GMO_AOZORA_REMITTER_ACCOUNT_ID=
CRON_SECRET=
HIBARAI_DAILY_WITHDRAWAL_COUNT_LIMIT=5
HIBARAI_DAILY_WITHDRAWAL_AMOUNT_LIMIT=50000
HIBARAI_MONTHLY_WITHDRAWAL_COUNT_LIMIT=10
HIBARAI_MONTHLY_WITHDRAWAL_AMOUNT_LIMIT=150000
HIBARAI_DEFAULT_FEE_JPY=143
